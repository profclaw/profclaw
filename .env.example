# GLINR Task Manager Environment Configuration
# Copy this file to .env and fill in your values
# Only the variables you need are required - most have sensible defaults

# ════════════════════════════════════════════════════════════════════════════════
# SERVER
# ════════════════════════════════════════════════════════════════════════════════

PORT=3000
NODE_ENV=development
# Allowed CORS origins (comma-separated for multiple)
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ════════════════════════════════════════════════════════════════════════════════
# STORAGE
# ════════════════════════════════════════════════════════════════════════════════

# Storage backend: memory, local (persistent SQLite), libsql (Turso)
STORAGE_TIER=local
# Path for file-based storage
DATA_PATH=./data

# LibSQL (for production - use Turso or local libsql-server)
# LIBSQL_URL=libsql://your-db.turso.io
# LIBSQL_AUTH_TOKEN=your_token_here

# ════════════════════════════════════════════════════════════════════════════════
# QUEUE (Optional - enables background jobs)
# ════════════════════════════════════════════════════════════════════════════════

# REDIS_URL=redis://localhost:6379
# GLINR_REQUIRE_REDIS=false

# ════════════════════════════════════════════════════════════════════════════════
# FEATURES
# ════════════════════════════════════════════════════════════════════════════════

# Enable scheduled job execution
ENABLE_CRON=true

# Task processing concurrency
TASK_CONCURRENCY=2

# ════════════════════════════════════════════════════════════════════════════════
# AI PROVIDERS (at least one required for chat features)
# ════════════════════════════════════════════════════════════════════════════════

# Anthropic (Claude) - Recommended for agentic tasks
# ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (GPT-4, GPT-4o, o1, etc.)
# OPENAI_API_KEY=sk-xxx

# Google (Gemini)
# GOOGLE_GENERATIVE_AI_API_KEY=xxx

# Azure OpenAI (alternative to OpenAI)
# AZURE_OPENAI_API_KEY=xxx
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Groq (fast inference for open models)
# GROQ_API_KEY=gsk_xxx

# Ollama (local models - free)
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_PORT=11434

# ════════════════════════════════════════════════════════════════════════════════
# TOOL EXECUTION
# ════════════════════════════════════════════════════════════════════════════════

# OpenClaw Configuration (AI coding agent)
# OPENCLAW_BASE_URL=http://localhost:18789
# OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
# OPENCLAW_WORKING_DIR=~/openclaw-workdir

# Claude Code (optional - auto-detected if installed)
# CLAUDE_WORKING_DIR=

# Tool pool settings
POOL_MAX_CONCURRENT=50
POOL_MAX_QUEUE_SIZE=200
POOL_TIMEOUT_MS=300000
POOL_QUEUE_TIMEOUT_MS=30000

# ════════════════════════════════════════════════════════════════════════════════
# GITHUB INTEGRATION
# ════════════════════════════════════════════════════════════════════════════════

# GitHub personal access token or GitHub App token
# GITHUB_TOKEN=ghp_xxx
# GITHUB_WEBHOOK_SECRET=your-webhook-secret

# OAuth App (for user authentication)
# GITHUB_CLIENT_ID=xxx
# GITHUB_CLIENT_SECRET=xxx

# Issue polling
# GITHUB_AI_TASK_LABEL=ai-task
# GITHUB_AI_REVIEW_LABEL=ai-review
# GITHUB_REPOS_TO_POLL=your-org/your-repo

# ════════════════════════════════════════════════════════════════════════════════
# JIRA INTEGRATION
# ════════════════════════════════════════════════════════════════════════════════

# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_WEBHOOK_SECRET=your-jira-webhook-secret
# JIRA_AI_TASK_LABEL=ai-task
# JIRA_CLIENT_ID=xxx
# JIRA_CLIENT_SECRET=xxx
# JIRA_CLOUD_ID=xxx

# ════════════════════════════════════════════════════════════════════════════════
# LINEAR INTEGRATION
# ════════════════════════════════════════════════════════════════════════════════

# LINEAR_API_KEY=lin_api_xxx
# LINEAR_WEBHOOK_SECRET=xxx

# ════════════════════════════════════════════════════════════════════════════════
# SLACK INTEGRATION
# ════════════════════════════════════════════════════════════════════════════════

# Bot token (OAuth)
# SLACK_BOT_TOKEN=xoxb-xxx
# SLACK_SIGNING_SECRET=xxx
# SLACK_APP_TOKEN=xapp-xxx

# Webhook notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# SLACK_CHANNEL=#ai-tasks
# SLACK_NOTIFY_ON_START=false
# SLACK_NOTIFY_ON_SUCCESS=true
# SLACK_NOTIFY_ON_FAILURE=true

# ════════════════════════════════════════════════════════════════════════════════
# DISCORD INTEGRATION
# ════════════════════════════════════════════════════════════════════════════════

# DISCORD_BOT_TOKEN=xxx
# DISCORD_APPLICATION_ID=xxx
# DISCORD_PUBLIC_KEY=xxx
# DISCORD_CLIENT_SECRET=xxx

# ════════════════════════════════════════════════════════════════════════════════
# TELEGRAM INTEGRATION
# ════════════════════════════════════════════════════════════════════════════════

# TELEGRAM_BOT_TOKEN=xxx

# ════════════════════════════════════════════════════════════════════════════════
# WHATSAPP INTEGRATION
# ════════════════════════════════════════════════════════════════════════════════

# WHATSAPP_ACCESS_TOKEN=xxx
# WHATSAPP_PHONE_NUMBER_ID=xxx
# WHATSAPP_VERIFY_TOKEN=xxx

# ════════════════════════════════════════════════════════════════════════════════
# SEARCH & EMBEDDINGS
# ════════════════════════════════════════════════════════════════════════════════

# Web search via SearXNG
SEARXNG_URL=https://searx.tiekoetter.com

# Embedding provider: local, openai, voyage
EMBEDDING_PROVIDER=local
# VOYAGE_API_KEY=xxx

# ════════════════════════════════════════════════════════════════════════════════
# DOCKER / MONITORING (docker-compose only)
# ════════════════════════════════════════════════════════════════════════════════

# REDIS_PORT=6379
# REDIS_COMMANDER_PORT=8081
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001
# GRAFANA_PASSWORD=admin
